# ─────────────────────────────────────────────────────
# Paddle Billing (결제 PG — 현재 활성)
# Sandbox: sandbox.paddle.com / sandbox-api.paddle.com
# Live:    paddle.com / api.paddle.com
# ─────────────────────────────────────────────────────

# Paddle 환경: "sandbox" 또는 "production"
NEXT_PUBLIC_PADDLE_ENVIRONMENT=sandbox

# Paddle Client-side Token (프론트엔드 Paddle.js 초기화용)
# Paddle 대시보드 > Developer Tools > Authentication에서 발급
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=test_your-client-token

# Paddle API Key (서버사이드 API 호출용 — 절대 NEXT_PUBLIC 금지)
# Paddle 대시보드 > Developer Tools > Authentication에서 발급
PADDLE_API_KEY=pdl_sdbx_your-api-key

# Paddle Webhook Secret (웹훅 서명 검증용)
# Paddle 대시보드 > Notifications > Webhook에서 발급
# Webhook 등록 URL: https://ai-native-playbook.com/api/webhooks/paddle
# 구독 이벤트: transaction.completed, transaction.payment_failed
PADDLE_WEBHOOK_SECRET=your-webhook-signing-secret

# Paddle Price IDs — 각 상품의 Price ID (Sandbox/Live 각각 별도)
# Paddle 대시보드에서 상품 생성 후 Price ID 복사
PADDLE_PRICE_ID_BUNDLE=pri_01abc_bundle
PADDLE_PRICE_ID_VOL1=pri_01abc_vol1
PADDLE_PRICE_ID_VOL2=pri_01abc_vol2
PADDLE_PRICE_ID_VOL3=pri_01abc_vol3
PADDLE_PRICE_ID_VOL4=pri_01abc_vol4
PADDLE_PRICE_ID_VOL5=pri_01abc_vol5
PADDLE_PRICE_ID_VOL6=pri_01abc_vol6

# ─────────────────────────────────────────────────────
# LemonSqueezy Checkout URLs (주석처리 — 비활성)
# 프로덕션 전환 확인 후 삭제 예정
# ─────────────────────────────────────────────────────

# NEXT_PUBLIC_LS_BUNDLE_URL=https://your-store.lemonsqueezy.com/checkout/buy/bundle-product-id
# NEXT_PUBLIC_LS_PRODUCT_1_URL=https://your-store.lemonsqueezy.com/checkout/buy/vol1-product-id
# NEXT_PUBLIC_LS_PRODUCT_2_URL=https://your-store.lemonsqueezy.com/checkout/buy/vol2-product-id
# NEXT_PUBLIC_LS_PRODUCT_3_URL=https://your-store.lemonsqueezy.com/checkout/buy/vol3-product-id
# NEXT_PUBLIC_LS_PRODUCT_4_URL=https://your-store.lemonsqueezy.com/checkout/buy/vol4-product-id
# NEXT_PUBLIC_LS_PRODUCT_5_URL=https://your-store.lemonsqueezy.com/checkout/buy/vol5-product-id
# NEXT_PUBLIC_LS_PRODUCT_6_URL=https://your-store.lemonsqueezy.com/checkout/buy/vol6-product-id
# LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-signing-secret

# ─────────────────────────────────────────────────────
# Brevo (구매 확인 이메일)
# ─────────────────────────────────────────────────────
BREVO_API_KEY=xkeysib-your-brevo-api-key

# ─────────────────────────────────────────────────────
# Telegram (결제 완료 CEO 알림)
# ─────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ─────────────────────────────────────────────────────
# 공통
# ─────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://ai-native-playbook.com

# ─────────────────────────────────────────────────────
# Sentry (에러 모니터링)
# ─────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=newbizsoft
SENTRY_PROJECT=ai-architect-global

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─────────────────────────────────────────────────────
# GitHub (blog post persistence across Vercel deploys)
# ─────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your-personal-access-token
GITHUB_BLOG_BRANCH=main
